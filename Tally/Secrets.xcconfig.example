// Copy this file to Secrets.xcconfig and fill in your values.
// Secrets.xcconfig is gitignored — never commit real keys.

CLERK_PUBLISHABLE_KEY = pk_test_YOUR_KEY_HERE

// API_BASE_URL: leave unset for local development.
// DEBUG builds fall back to http://localhost:8080 automatically.
//
// For staging/production, set the full URL below.
// xcconfig treats // as a comment, so write the URL without slashes using
// the $() empty-variable escape: http:$()//your-server.com
// Example:
// API_BASE_URL = https:$()//api.example.com
