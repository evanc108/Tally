# ─────────────────────────────────────────────────────────────────────────────
# Tally Backend — Environment Variable Template
#
# This file IS committed to git. It documents every required variable
# but contains no real secrets. Copy it to .env and fill in real values.
#
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

DATABASE_URL=postgres://tally:tally_secret@postgres:5432/tally?sslmode=disable
REDIS_URL=redis://redis:6379
PORT=8080
ENV=development

# HMAC secret used to verify /v1/auth/jit webhook signatures from the card processor.
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=REPLACE_WITH_RANDOM_SECRET

# ── Stripe ───────────────────────────────────────────────────────────────────
# Leave empty to use mock clients (no real Stripe calls — good for local dev).

# Secret key from the Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=

# Signing secret for /v1/webhooks/stripe/* (stripe.ConstructEvent).
# - Local KYC: run ./scripts/stripe_listen_identity.sh and paste the whsec_... here.
# - Deployed: Stripe Dashboard → Webhooks → Add endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=

# Card product ID from Stripe Issuing → Card designs
STRIPE_ISSUING_CARD_PRODUCT=

# ── Clerk ─────────────────────────────────────────────────────────────────────
# Leave empty to disable JWT auth (local dev only — uses DEV_USER_ID instead).
# Set to: Clerk Dashboard → API Keys → Advanced → JWKS URL
CLERK_JWKS_URL=

# Injected as the authenticated user ID when CLERK_JWKS_URL is unset.
DEV_USER_ID=dev-user-local
