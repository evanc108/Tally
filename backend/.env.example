# ─────────────────────────────────────────────────────────────────────────────
# Tally Backend — Environment Variable Template
#
# This file IS committed to git. It documents every required variable
# but contains no real secrets. Copy it to .env and fill in real values.
#
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

DATABASE_URL=postgres://tally:tally_secret@postgres:5432/tally?sslmode=disable
REDIS_URL=redis://redis:6379
PORT=8080
ENV=development

# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=REPLACE_WITH_RANDOM_SECRET

# Highnote
HIGHNOTE_API_KEY=                        # empty = mock client
HIGHNOTE_CARD_PRODUCT_ID=               # from Highnote dashboard
HIGHNOTE_WEBHOOK_SECRET=REPLACE_WITH_HIGHNOTE_SIGNING_SECRET

# Plaid (empty = mock client)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Clerk — leave empty to disable JWT auth (local dev only)
# Set to your JWKS URL from: Clerk Dashboard → API Keys → Advanced → JWKS URL
# Format: https://<your-frontend-api>.clerk.accounts.dev/.well-known/jwks.json
CLERK_JWKS_URL=
